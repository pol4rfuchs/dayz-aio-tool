# Created automatically by install-windows.bat.
# Keep this file private. Do not commit real secrets.
PORT=8090
HOST=0.0.0.0
DATA_DIR=../../data
DAYZ_ROOT=../../dayz-server

# Required unless DAYZ_AIO_AUTH_DISABLED=true.
DAYZ_AIO_API_KEY=replace-with-strong-random-api-key
DAYZ_AIO_SECRET_KEY=replace-with-strong-random-secret-key
DAYZ_AIO_CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
DAYZ_AIO_RATE_LIMIT_PER_MINUTE=300
DAYZ_AIO_AUTH_FAILURE_LIMIT_PER_MINUTE=20
DAYZ_AIO_RATE_LIMIT_BUCKET_TTL_MS=600000
DAYZ_AIO_RATE_LIMIT_CLEANUP_INTERVAL_MS=300000
DAYZ_AIO_AUTH_DISABLED=false

# Experimental: enable only on an isolated test server after verifying RCON credentials.
DAYZ_AIO_BATTLEYE_RCON_ENABLED=false
DAYZ_AIO_RCON_TIMEOUT_MS=5000
DAYZ_AIO_SCHEDULE_MAX_RETRIES=2
DAYZ_AIO_SCHEDULE_RETRY_DELAY_MINUTES=5
DAYZ_AIO_SCHEDULE_ESCALATE_AFTER_FAILURES=3

DAYZ_AIO_LOG_DIR=../../logs
DAYZ_AIO_BACKEND_LOG_MAX_SIZE_BYTES=5242880
DAYZ_AIO_BACKEND_LOG_MAX_FILES=5

DAYZ_AIO_FRONTEND_PORT=3100
